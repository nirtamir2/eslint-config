{
  "compilerOptions": {
    "target": "ESNext",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": [
    "./dist/**/*.*",
    "./fixtures/**/*.*",
    "./_fixtures/**/*.*",
    "./stuff/**/*.*"
  ]
}
